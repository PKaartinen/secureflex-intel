# SecureFlex Intel — Environment Variables
# Copy this file to .env and fill in your keys

# Companies House API Key (FREE)
# Get one at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=your-key-here

# OpenAI API Key (OPTIONAL — for future AI features)
# OPENAI_API_KEY=sk-...

# Pipeline CSV path override (optional)
# Default: auto-detects sibling secureflex-growth/data/pipeline_master.csv
# PIPELINE_CSV_PATH=/path/to/pipeline_master.csv

# Adzuna Job Search API (replaces Indeed + Reed RSS feeds)
# Register free at https://developer.adzuna.com/
ADZUNA_APP_ID=your-app-id-here
ADZUNA_APP_KEY=your-app-key-here

# TheyWorkForYou API (replaces Hansard RSS for Martyn's Law monitoring)
# Register free at https://www.theyworkforyou.com/api/key
TWFY_API_KEY=your-key-here
